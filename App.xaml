<Application x:Class="CybersecurityChatbot.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">

    <Application.Resources>

        <!-- ══ Colours ══════════════════════════════════════════════════════════ -->
        <SolidColorBrush x:Key="BgDark"       Color="#0D1117"/>
        <SolidColorBrush x:Key="BgMid"        Color="#161B22"/>
        <SolidColorBrush x:Key="BgPanel"      Color="#21262D"/>
        <SolidColorBrush x:Key="AccentCyan"   Color="#00B4D8"/>
        <SolidColorBrush x:Key="AccentGreen"  Color="#3FB950"/>
        <SolidColorBrush x:Key="AccentYellow" Color="#F0A500"/>
        <SolidColorBrush x:Key="AccentRed"    Color="#F85149"/>
        <SolidColorBrush x:Key="TextMain"     Color="#E6EDF3"/>
        <SolidColorBrush x:Key="TextMuted"    Color="#8B949E"/>
        <SolidColorBrush x:Key="BotBubble"    Color="#1C3A4A"/>
        <SolidColorBrush x:Key="UserBubble"   Color="#1A3A1A"/>
        <SolidColorBrush x:Key="BorderColor"  Color="#30363D"/>

        <!-- ══ Send / primary button ════════════════════════════════════════════ -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource AccentCyan}"/>
            <Setter Property="Foreground"      Value="#0D1117"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Padding"         Value="18,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0096C7"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0077A8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#30363D"/>
                                <Setter Property="Foreground" Value="#8B949E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ Chip / quick-topic button ════════════════════════════════════════ -->
        <Style x:Key="ChipBtn" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource BgPanel}"/>
            <Setter Property="Foreground"      Value="{StaticResource AccentCyan}"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Padding"         Value="10,5"/>
            <Setter Property="Margin"          Value="3,2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="{StaticResource AccentCyan}"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1C3A4A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ Dark TextBox ══════════════════════════════════════════════════════ -->
        <Style x:Key="DarkInput" TargetType="TextBox">
            <Setter Property="Background"      Value="{StaticResource BgPanel}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextMain}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Padding"         Value="10,8"/>
            <Setter Property="CaretBrush"      Value="{StaticResource AccentCyan}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource AccentCyan}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#8B949E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ Global text default ════════════════════════════════════════════════ -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{StaticResource TextMain}"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="FontSize"    Value="13"/>
        </Style>

    </Application.Resources>
</Application>
