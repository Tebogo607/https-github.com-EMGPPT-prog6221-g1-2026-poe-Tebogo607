<Window x:Class="CybersecurityChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🛡️ Cybersecurity Awareness Bot — Part 3"
        Height="750" Width="1150"
        MinHeight="600" MinWidth="950"
        WindowStartupLocation="CenterScreen"
        Background="#0D1117">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="265"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════ SIDEBAR ══════════════════════════════ -->
        <Border Grid.Column="0" Background="#161B22"
                BorderBrush="#30363D" BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- Logo -->
                <Border DockPanel.Dock="Top" Background="#0D1117" Padding="14,16">
                    <StackPanel>
                        <TextBlock Text="🛡️ CyberSec Bot" FontSize="17" FontWeight="Bold"
                                   Foreground="#00B4D8" HorizontalAlignment="Center"/>
                        <TextBlock Text="Protecting South Africans Online"
                                   FontSize="10" Foreground="#8B949E"
                                   HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        <Border Margin="0,8,0,0" Background="#21262D" CornerRadius="6" Padding="6,5">
                            <TextBlock FontFamily="Consolas" FontSize="7.5" Foreground="#00B4D8"
                                       HorizontalAlignment="Center" TextAlignment="Center">
╔══════════════════════╗&#10;║  CYBERSEC AWARENESS  ║&#10;║  BOT  🛡️  Part 3     ║&#10;╚══════════════════════╝
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Memory panel -->
                <Border DockPanel.Dock="Top" Background="#21262D" Margin="10,5" CornerRadius="8" Padding="12,9">
                    <StackPanel>
                        <TextBlock Text="👤 SESSION MEMORY" FontSize="10" FontWeight="Bold" Foreground="#8B949E" Margin="0,0,0,5"/>
                        <TextBlock x:Name="MemoryName"  Text="Name: —"           FontSize="12" Foreground="#E6EDF3"/>
                        <TextBlock x:Name="MemoryTopic" Text="Favourite: —"      FontSize="11" Foreground="#8B949E" Margin="0,2,0,0" TextWrapping="Wrap"/>
                        <TextBlock x:Name="MemoryCount" Text="Topics explored: 0" FontSize="11" Foreground="#8B949E" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Part 3 feature buttons -->
                <Border DockPanel.Dock="Top" Margin="10,0,10,5">
                    <StackPanel>
                        <TextBlock Text="PART 3 FEATURES" FontSize="10" FontWeight="Bold" Foreground="#F0A500" Margin="0,0,0,6"/>
                        <Button Content="📋 View My Tasks"       Style="{StaticResource ChipBtn}" Tag="view tasks"    Click="Chip_Click" HorizontalAlignment="Stretch" Margin="0,2"/>
                        <Button Content="➕ Add a Task"          Style="{StaticResource ChipBtn}" Tag="add task"      Click="Chip_Click" HorizontalAlignment="Stretch" Margin="0,2"/>
                        <Button Content="✅ Complete a Task"     Style="{StaticResource ChipBtn}" Tag="complete task"  Click="Chip_Click" HorizontalAlignment="Stretch" Margin="0,2"/>
                        <Button Content="🗑️  Delete a Task"      Style="{StaticResource ChipBtn}" Tag="delete task"   Click="Chip_Click" HorizontalAlignment="Stretch" Margin="0,2"/>
                        <Button Content="🎮 Start Quiz"          Style="{StaticResource ChipBtn}" Tag="quiz"          Click="Chip_Click" HorizontalAlignment="Stretch" Margin="0,2" Foreground="#F0A500" BorderBrush="#F0A500"/>
                        <Button Content="📜 Activity Log"        Style="{StaticResource ChipBtn}" Tag="activity log"  Click="Chip_Click" HorizontalAlignment="Stretch" Margin="0,2"/>
                    </StackPanel>
                </Border>

                <!-- Quick topics (Part 2) -->
                <Border DockPanel.Dock="Top" Margin="10,0,10,5">
                    <StackPanel>
                        <TextBlock Text="QUICK TOPICS" FontSize="10" FontWeight="Bold" Foreground="#8B949E" Margin="0,0,0,5"/>
                        <WrapPanel>
                            <Button Content="🔑 Passwords" Style="{StaticResource ChipBtn}" Tag="Tell me about password safety" Click="Chip_Click"/>
                            <Button Content="🎣 Phishing"  Style="{StaticResource ChipBtn}" Tag="What is phishing?"            Click="Chip_Click"/>
                            <Button Content="🔒 Privacy"   Style="{StaticResource ChipBtn}" Tag="Tell me about privacy"        Click="Chip_Click"/>
                            <Button Content="🌐 Browsing"  Style="{StaticResource ChipBtn}" Tag="How to browse safely?"        Click="Chip_Click"/>
                            <Button Content="🦠 Malware"   Style="{StaticResource ChipBtn}" Tag="Tell me about malware"        Click="Chip_Click"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Sentiment (Part 2) -->
                <Border DockPanel.Dock="Top" Margin="10,0,10,5">
                    <StackPanel>
                        <TextBlock Text="HOW ARE YOU FEELING?" FontSize="10" FontWeight="Bold" Foreground="#8B949E" Margin="0,0,0,5"/>
                        <WrapPanel>
                            <Button Content="😰 Worried"    Style="{StaticResource ChipBtn}" Tag="I'm worried about online scams"          Click="Chip_Click"/>
                            <Button Content="🤔 Curious"    Style="{StaticResource ChipBtn}" Tag="I'm curious about cybersecurity"         Click="Chip_Click"/>
                            <Button Content="😤 Frustrated" Style="{StaticResource ChipBtn}" Tag="I'm frustrated I don't understand this"  Click="Chip_Click"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Clear -->
                <Border DockPanel.Dock="Bottom" Margin="10,8">
                    <Button Content="🗑️  Clear Chat" Style="{StaticResource ChipBtn}"
                            Click="ClearChat_Click" HorizontalAlignment="Stretch"
                            Foreground="#F85149" BorderBrush="#F85149"/>
                </Border>
                <Border/>
            </DockPanel>
        </Border>

        <!-- ══════════════════════════ MAIN AREA ════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="68"/>
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0" Background="#161B22"
                    BorderBrush="#30363D" BorderThickness="0,0,0,1" Padding="18,0">
                <DockPanel VerticalAlignment="Center">
                    <TextBlock Text="🛡️  Cybersecurity Awareness Assistant — Part 3"
                               FontSize="14" FontWeight="SemiBold" Foreground="#E6EDF3"/>
                    <TextBlock Text="● Online" FontSize="11" Foreground="#3FB950"
                               HorizontalAlignment="Right" DockPanel.Dock="Right" VerticalAlignment="Center"
                               Margin="0,0,0,0"/>
                    <TextBlock x:Name="DbStatusLabel" Text="● DB: checking..." FontSize="11" Foreground="#8B949E"
                               HorizontalAlignment="Right" DockPanel.Dock="Right" VerticalAlignment="Center"
                               Margin="0,0,16,0"/>
                </DockPanel>
            </Border>

            <!-- Name banner -->
            <Border x:Name="NameBanner" Grid.Row="1" Background="#21262D"
                    BorderBrush="#F0A500" BorderThickness="0,0,0,2" Padding="18,12">
                <DockPanel>
                    <Button Content="Let's go ➤" Style="{StaticResource PrimaryBtn}"
                            Background="#F0A500" DockPanel.Dock="Right"
                            Click="ConfirmName_Click" Margin="8,0,0,0"/>
                    <TextBox x:Name="NameBox" Style="{StaticResource DarkInput}"
                             Width="190" DockPanel.Dock="Right"
                             VerticalAlignment="Center" KeyDown="NameBox_KeyDown"/>
                    <TextBlock Text="👤  What is your name?"
                               VerticalAlignment="Center" Foreground="#E6EDF3" Margin="0,0,10,0"/>
                </DockPanel>
            </Border>

            <!-- Chat -->
            <ScrollViewer x:Name="Scroller" Grid.Row="2"
                          VerticalScrollBarVisibility="Auto" Padding="14,10">
                <StackPanel x:Name="ChatPanel"/>
            </ScrollViewer>

            <!-- Input bar -->
            <Border Grid.Row="3" Background="#161B22"
                    BorderBrush="#30363D" BorderThickness="0,1,0,0" Padding="14,10">
                <DockPanel>
                    <Button x:Name="SendBtn" Content="Send  ➤"
                            Style="{StaticResource PrimaryBtn}"
                            DockPanel.Dock="Right" Click="Send_Click"
                            Width="88" IsEnabled="False" Margin="10,0,0,0"/>
                    <TextBox x:Name="InputBox" Style="{StaticResource DarkInput}"
                             IsEnabled="False" KeyDown="Input_KeyDown"
                             VerticalAlignment="Center"/>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
